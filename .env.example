# Postgres compartilhado (ver ericsantos.eu/infra/) — o role/database "banco"
# já é criado lá. POSTGRES_PASSWORD deve ser igual a BANCO_DB_PASSWORD no
# infra/.env do droplet.
POSTGRES_DB=banco
POSTGRES_USER=banco
POSTGRES_PASSWORD=change-me

# Caminho no host com os PDFs que você (admin) já baixava manualmente antes
# do upload multiusuário — pastas de ano (2021, 2022, ..., 2026). Continua
# só de leitura; não é usado pelos demais usuários (eles fazem upload).
PDF_ROOT_HOST=../pdf

FRONTEND_PORT=5173

# Gere com: openssl rand -hex 32
SECRET_KEY=change-me-generate-a-real-secret

# Sessão de login dura esse tanto de dias antes de precisar logar de novo
JWT_EXPIRE_DAYS=7

# Conta de administrador criada automaticamente no primeiro start do backend
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Dias que um PDF enviado fica disponível antes de ser removido do disco
# (os lançamentos já importados continuam no banco depois disso)
RETENTION_DAYS=7

# Origem do frontend, usada pelo CORS do backend. Se você acessa a aplicação
# por um domínio (via reverse proxy), troque para esse domínio (com https://).
FRONTEND_ORIGIN=http://localhost:5173

# Chave de API da Anthropic (Claude), usada pelo assistente financeiro de IA.
# Opcional — sem ela, a tela do assistente mostra um erro amigável, mas o
# resto do app funciona normalmente. Gere em https://console.anthropic.com
ANTHROPIC_API_KEY=
